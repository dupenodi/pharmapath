AGENT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
CORS_ORIGINS=["http://localhost:3000"]

# "full" (default) loads prescription + OTC drugs (~670MB peak RAM during
# the startup graph build). "rx_only" drops OTC and cuts that to ~370MB --
# set this when hosting on a memory-constrained free tier (e.g. 512MB).
GRAPH_SCOPE=full
